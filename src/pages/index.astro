---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import Process from '../components/sections/Process.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import CTABanner from '../components/sections/CTABanner.astro';
---

<BaseLayout
  title="Solvio — Agence d'automatisation de processus métier"
  description="Solvio automatise vos workflows, intègre l'IA dans vos processus et vous libère des tâches à faible valeur. Gagnez du temps, scalez votre activité."
>
  <Header />
  <main>
    <Hero />
    <Services />
    <Process />
    <Testimonials />
    <CTABanner />
  </main>
  <Footer />
</BaseLayout>
