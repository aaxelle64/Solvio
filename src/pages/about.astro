---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CTABanner from '../components/sections/CTABanner.astro';

const values = [
  {
    title: 'Pragmatisme',
    description: 'Nous choisissons toujours la solution la plus simple qui résout le problème. Pas de sur-ingénierie, pas de complexité inutile.',
  },
  {
    title: 'Transparence',
    description: 'Pas de boîte noire. Vous comprenez ce que nous construisons, pourquoi, et comment l\'utiliser sans nous.',
  },
  {
    title: 'Impact mesurable',
    description: 'Chaque projet démarre avec des métriques claires. À la livraison, vous savez exactement ce que vous avez gagné.',
  },
  {
    title: 'Durabilité',
    description: 'Nous construisons des systèmes que votre équipe peut maintenir et faire évoluer — pas des solutions qui créent de la dépendance.',
  },
];
---

<BaseLayout
  title="À propos — Solvio"
  description="Découvrez l'équipe et les valeurs de Solvio, agence d'automatisation de processus métier basée en France."
>
  <Header />
  <main>

    <!-- Hero -->
    <section class="page-header section">
      <div class="container">
        <div class="about-hero">
          <div class="about-hero-content">
            <span class="label-caps">Notre histoire</span>
            <h1>Construits par des ops,<br />pour des ops.</h1>
            <p>
              Solvio est né d'un constat simple : trop d'équipes passent des heures sur des tâches que des machines pourraient faire mieux et plus vite. Nous sommes là pour changer ça.
            </p>
            <p>
              Notre équipe combine expertise en automatisation, développement logiciel et compréhension des enjeux business pour livrer des solutions qui fonctionnent vraiment — pas des POC qui traînent dans des tiroirs.
            </p>
          </div>
          <div class="about-hero-stat">
            <div class="big-stat">
              <span class="big-number">50+</span>
              <span class="big-label">processus automatisés</span>
            </div>
            <div class="big-stat">
              <span class="big-number">30+</span>
              <span class="big-label">clients accompagnés</span>
            </div>
            <div class="big-stat">
              <span class="big-number">98%</span>
              <span class="big-label">de satisfaction client</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="section values-section">
      <div class="container">
        <div class="values-header">
          <span class="label-caps">Ce qui nous guide</span>
          <h2>Des principes non négociables.</h2>
        </div>
        <div class="values-grid">
          {values.map(v => (
            <div class="value-card">
              <h3>{v.title}</h3>
              <p>{v.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Manifesto -->
    <section class="section manifesto-section">
      <div class="container">
        <div class="manifesto">
          <span class="label-caps">Notre conviction</span>
          <blockquote>
            "L'automatisation n'est pas là pour remplacer les humains. Elle est là pour les libérer de ce qui les empêche d'être vraiment humains au travail — la créativité, la décision, la relation."
          </blockquote>
          <cite>— L'équipe Solvio</cite>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</BaseLayout>

<style>
.page-header {
  border-bottom: 0.5px solid var(--color-border);
}
.page-header .label-caps { display: block; margin-bottom: 1.25rem; }
.page-header h1 { margin-bottom: 1.5rem; }
.page-header p {
  font-size: 1.0625rem;
  color: var(--color-text-secondary);
  max-width: 520px;
  margin-bottom: 1rem;
}

.about-hero {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 5rem;
  align-items: start;
}

.about-hero-stat {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 0.5px solid var(--color-border);
  border-radius: 12px;
  overflow: hidden;
  min-width: 180px;
}

.big-stat {
  padding: 1.5rem;
  border-bottom: 0.5px solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.big-stat:last-child { border-bottom: none; }

.big-number {
  font-family: Georgia, serif;
  font-size: 2rem;
  color: var(--color-teal);
  letter-spacing: -1px;
}
.big-label {
  font-size: 0.75rem;
  color: var(--color-text-muted);
}

/* Values */
.values-section { background: var(--color-surface); border-top: 0.5px solid var(--color-border); border-bottom: 0.5px solid var(--color-border); }
.values-header { margin-bottom: 3rem; }
.values-header .label-caps { display: block; margin-bottom: 0.75rem; }
.values-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--color-border);
  border: 0.5px solid var(--color-border);
  border-radius: 12px;
  overflow: hidden;
}
.value-card {
  background: var(--color-surface);
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.value-card h3 { font-size: 1rem; }
.value-card p { font-size: 0.875rem; color: var(--color-text-secondary); }

/* Manifesto */
.manifesto {
  max-width: 680px;
  margin-inline: auto;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.manifesto blockquote {
  font-family: Georgia, serif;
  font-size: clamp(1.25rem, 2.5vw, 1.625rem);
  color: var(--color-text-primary);
  line-height: 1.5;
  letter-spacing: -0.25px;
}
.manifesto cite {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  font-style: normal;
}

@media (max-width: 900px) {
  .about-hero { grid-template-columns: 1fr; }
  .about-hero-stat { flex-direction: row; min-width: 0; }
  .big-stat { border-bottom: none; border-right: 0.5px solid var(--color-border); flex: 1; }
  .big-stat:last-child { border-right: none; }
  .values-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .about-hero-stat { flex-direction: column; }
  .big-stat { border-right: none; border-bottom: 0.5px solid var(--color-border); }
  .values-grid { grid-template-columns: 1fr; }
}
</style>
