---
const testimonials = [
  {
    quote: "En trois semaines, Solvio a automatisé notre onboarding client qui nous prenait 4 heures par dossier. Aujourd'hui c'est moins de 20 minutes sans intervention manuelle.",
    author: "Claire Fontaine",
    role: "COO",
    company: "DataFlow SAS",
    initial: "CF",
  },
  {
    quote: "L'audit a révélé 12 process automatisables. On a commencé par les 3 à plus fort ROI — résultat : 2 ETP libérés en moins de deux mois. Retour sur investissement immédiat.",
    author: "Mehdi Okacha",
    role: "Directeur des Opérations",
    company: "Nexora Group",
    initial: "MO",
  },
  {
    quote: "Leur approche est différente : pas de solution générique, ils comprennent vraiment votre métier avant de proposer quoi que ce soit. La qualité du livrable est irréprochable.",
    author: "Sophie Renard",
    role: "CEO & Co-fondatrice",
    company: "Luminance Studio",
    initial: "SR",
  },
];
---

<section class="section testimonials-section">
  <div class="container">

    <div class="section-header">
      <span class="label-caps">Témoignages</span>
      <h2>Ce que disent<br />nos clients.</h2>
    </div>

    <div class="testimonials-grid">
      {testimonials.map(t => (
        <blockquote class="testimonial-card">
          <div class="quote-mark" aria-hidden="true">"</div>
          <p class="quote-text">{t.quote}</p>
          <footer class="quote-author">
            <div class="author-avatar" aria-hidden="true">{t.initial}</div>
            <div class="author-info">
              <cite class="author-name">{t.author}</cite>
              <span class="author-meta">{t.role} · {t.company}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

  </div>
</section>

<style>
.section-header {
  text-align: center;
  max-width: 480px;
  margin-inline: auto;
  margin-bottom: 4rem;
}
.section-header .label-caps { display: block; margin-bottom: 1rem; }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}

.testimonial-card {
  background: var(--color-surface);
  border: 0.5px solid var(--color-border);
  border-radius: 12px;
  padding: 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  position: relative;
  transition: border-color 0.2s ease;
}
.testimonial-card:hover {
  border-color: rgba(0, 200, 160, 0.2);
}

.quote-mark {
  font-family: Georgia, serif;
  font-size: 3.5rem;
  line-height: 1;
  color: var(--color-teal);
  opacity: 0.25;
  position: absolute;
  top: 1rem;
  right: 1.5rem;
}

.quote-text {
  font-size: 0.9375rem;
  color: var(--color-text-secondary);
  line-height: 1.7;
  flex: 1;
}

.quote-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 0.5px solid var(--color-border);
}

.author-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(0, 200, 160, 0.1);
  border: 0.5px solid rgba(0, 200, 160, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-teal);
  flex-shrink: 0;
}

.author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.author-name {
  font-style: normal;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-primary);
}

.author-meta {
  font-size: 0.75rem;
  color: var(--color-text-muted);
}

@media (max-width: 900px) {
  .testimonials-grid { grid-template-columns: 1fr; }
}
@media (min-width: 640px) and (max-width: 900px) {
  .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
  .testimonial-card:last-child { grid-column: 1 / -1; }
}
</style>
