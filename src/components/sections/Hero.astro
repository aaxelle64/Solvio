---
---

<section class="hero">
  <div class="container">
    <div class="hero-inner">

      <div class="hero-badge">
        <span class="label-caps">Agence d'automatisation</span>
      </div>

      <h1 class="hero-title">
        Automatisez ce<br />qui vous freine.
      </h1>

      <p class="hero-sub">
        Solvio conçoit et déploie des systèmes d'automatisation sur mesure —&nbsp;workflows, intégrations IA, connecteurs no-code — pour que votre équipe se concentre sur ce qui compte vraiment.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn-primary">
          Démarrer un projet
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M2.5 7H11.5M7.5 3L11.5 7L7.5 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/services" class="btn-ghost">
          Voir nos services
        </a>
      </div>

      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">3×</span>
          <span class="stat-label">plus vite à déployer</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">80%</span>
          <span class="stat-label">de tâches manuelles éliminées</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-value">24/7</span>
          <span class="stat-label">vos workflows tournent sans vous</span>
        </div>
      </div>

    </div>
  </div>

  <!-- Background grid decoration -->
  <div class="hero-grid" aria-hidden="true"></div>
</section>

<style>
.hero {
  position: relative;
  overflow: hidden;
  padding-block: 7rem 5rem;
}

.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(28, 34, 56, 0.4) 1px, transparent 1px),
    linear-gradient(90deg, rgba(28, 34, 56, 0.4) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 30%, transparent 100%);
  -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 0%, black 30%, transparent 100%);
  pointer-events: none;
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 680px;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  border: 0.5px solid var(--color-border);
  border-radius: 100px;
  padding: 6px 14px;
  margin-bottom: 2rem;
  background: rgba(13, 17, 32, 0.8);
}
.hero-badge::before {
  content: '';
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-teal);
  box-shadow: 0 0 6px var(--color-teal);
}

.hero-title {
  font-size: clamp(2.75rem, 6vw, 4.25rem);
  letter-spacing: -1.5px;
  line-height: 1.08;
  margin-bottom: 1.5rem;
  color: var(--color-text-primary);
}

.hero-sub {
  font-size: 1.0625rem;
  color: var(--color-text-secondary);
  line-height: 1.7;
  max-width: 560px;
  margin-bottom: 2.5rem;
  font-weight: 300;
}

.hero-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 3.5rem;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 0;
  border: 0.5px solid var(--color-border);
  border-radius: 12px;
  background: var(--color-surface);
  overflow: hidden;
  width: fit-content;
}

.stat {
  display: flex;
  flex-direction: column;
  padding: 1rem 1.5rem;
  gap: 0.2rem;
}

.stat-value {
  font-family: Georgia, serif;
  font-size: 1.5rem;
  color: var(--color-teal);
  letter-spacing: -0.5px;
}

.stat-label {
  font-size: 0.75rem;
  color: var(--color-text-muted);
  font-weight: 400;
  white-space: nowrap;
}

.stat-divider {
  width: 0.5px;
  background: var(--color-border);
  align-self: stretch;
}

@media (max-width: 640px) {
  .hero { padding-block: 4.5rem 3.5rem; }
  .hero-stats {
    flex-direction: column;
    width: 100%;
  }
  .stat-divider {
    width: 100%;
    height: 0.5px;
  }
  .stat { padding: 0.875rem 1.25rem; }
}
</style>
