---
const year = new Date().getFullYear();
const links = [
  { label: 'Services', href: '/services' },
  { label: 'À propos', href: '/about' },
  { label: 'Contact',  href: '/contact' },
];
---

<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="Solvio">
          <img src="/logo.svg" alt="Logo Solvio" width="28" height="28" />
          <span>Solvio</span>
        </a>
        <p>Automatisez ce qui vous freine.<br />Scalez ce qui vous définit.</p>
      </div>

      <nav aria-label="Liens footer">
        <ul role="list">
          {links.map(l => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </nav>

      <div class="footer-contact">
        <p class="label-caps">Contact</p>
        <a href="mailto:aaxelle644@gmail.com">aaxelle644@gmail.com</a>
      </div>
    </div>

    <hr class="divider" />

    <div class="footer-bottom">
      <p>© {year} Solvio. Tous droits réservés.</p>
      <a href="/mentions-legales">Mentions légales</a>
    </div>
  </div>
</footer>

<style>
footer {
  background: var(--color-surface);
  border-top: 0.5px solid var(--color-border);
  padding-block: 3.5rem 2rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: 3rem;
  align-items: start;
  margin-bottom: 2.5rem;
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.75rem;
  text-decoration: none;
}
.logo span {
  font-family: Georgia, serif;
  font-size: 1.125rem;
  letter-spacing: -1px;
  background: linear-gradient(135deg, #00F0C0, #4E8FFF, #9B5CF5);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.footer-brand p { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.6; }

nav ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
nav a { font-size: 0.875rem; color: var(--color-text-secondary); transition: color 0.15s; }
nav a:hover { color: var(--color-text-primary); }

.footer-contact { display: flex; flex-direction: column; gap: 0.5rem; }
.footer-contact a { font-size: 0.875rem; color: var(--color-text-secondary); transition: color 0.15s; }
.footer-contact a:hover { color: var(--color-teal); }

.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1.5rem;
}
.footer-bottom p, .footer-bottom a { font-size: 0.8125rem; color: var(--color-text-muted); }
.footer-bottom a:hover { color: var(--color-text-secondary); }

@media (max-width: 640px) {
  .footer-inner { grid-template-columns: 1fr; gap: 2rem; }
  .footer-bottom { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
}
</style>
