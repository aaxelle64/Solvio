---
const navLinks = [
  { label: 'Services',  href: '/services' },
  { label: 'À propos',  href: '/about' },
  { label: 'Contact',   href: '/contact' },
];
const currentPath = Astro.url.pathname;
---

<header>
  <div class="container">
    <nav aria-label="Navigation principale">
      <a href="/" class="logo" aria-label="Solvio — Accueil">
        <img src="/logo.svg" alt="Logo Solvio" width="32" height="32" />
        <span>Solvio</span>
      </a>

      <ul class="nav-links" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a href="/contact" class="btn-primary">Démarrer →</a>

      <button class="hamburger" aria-label="Ouvrir le menu" id="menu-toggle">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <rect x="2" y="5"    width="16" height="1.5" rx="1" fill="currentColor"/>
          <rect x="2" y="9.25" width="16" height="1.5" rx="1" fill="currentColor"/>
          <rect x="2" y="13.5" width="16" height="1.5" rx="1" fill="currentColor"/>
        </svg>
      </button>
    </nav>
  </div>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      {navLinks.map(link => (
        <li><a href={link.href} class="mobile-nav-link">{link.label}</a></li>
      ))}
      <li><a href="/contact" class="btn-primary" style="margin-top:0.5rem;">Démarrer →</a></li>
    </ul>
  </div>
</header>

<style>
header {
  position: sticky;
  top: 0;
  z-index: 50;
  background: rgba(6, 12, 26, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 0.5px solid var(--color-border);
}

nav {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 64px;
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-shrink: 0;
  margin-right: auto;
  text-decoration: none;
}
.logo span {
  font-family: Georgia, serif;
  font-size: 1.25rem;
  font-weight: 400;
  letter-spacing: -1px;
  background: linear-gradient(135deg, #00F0C0, #4E8FFF, #9B5CF5);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.nav-links { display: flex; align-items: center; gap: 0.25rem; list-style: none; }

.nav-link {
  font-size: 0.875rem;
  color: var(--color-text-secondary);
  padding: 6px 12px;
  border-radius: 6px;
  transition: color 0.15s;
}
.nav-link:hover, .nav-link.active { color: var(--color-text-primary); }

.hamburger {
  display: none;
  background: none;
  border: none;
  color: var(--color-text-secondary);
  cursor: pointer;
  padding: 4px;
}

.mobile-menu {
  display: none;
  background: var(--color-surface);
  border-bottom: 0.5px solid var(--color-border);
  padding: 1.25rem 2rem 1.5rem;
}
.mobile-menu ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
.mobile-nav-link {
  font-size: 1rem;
  color: var(--color-text-secondary);
  padding: 8px 0;
  display: block;
  transition: color 0.15s;
}
.mobile-nav-link:hover { color: var(--color-text-primary); }

@media (max-width: 768px) {
  .nav-links { display: none; }
  .hamburger { display: flex; }
  header .btn-primary { display: none; }
  .mobile-menu.open { display: block; }
}
</style>

<script>
const toggle = document.getElementById('menu-toggle');
const menu   = document.getElementById('mobile-menu');
toggle?.addEventListener('click', () => {
  const open = menu?.classList.toggle('open');
  menu?.setAttribute('aria-hidden', String(!open));
});
</script>
